<?xml version="1.0" encoding="utf-8"?>
<project>

	<meta title="Shark" package="com.brenninho.shark" version="0.1.0" company="Brenninho" />
	<app main="Main" file="Shark" path="export" />

	<window width="1280" height="720" fps="60" background="#00111F" hardware="true" vsync="false" antialiasing="0" />
	<window if="mobile" orientation="landscape" fullscreen="true" allow-shaders="true" />
	<window if="html5" resizable="true" allow-high-dpi="true" />
	<window if="desktop" resizable="true" />

	<source path="source" />

	<haxelib name="openfl" />
	<haxelib name="flixel" />
	<haxelib name="flixel-addons" />
	<haxelib name="flixel-ui" />
	<haxelib name="hscript" />
	<haxelib name="hxdiscord_rpc" if="cpp" />
	<haxelib name="hxcpp" if="cpp" />

	<assets path="assets/images" rename="assets/images" />
	<assets path="assets/data" rename="assets/data" />
	<assets path="assets/fonts" rename="assets/fonts" if="font" />

	<icon path="assets/images/icon.png" />

	<define name="FLX_NO_NATIVE_CURSOR" />
	<define name="FLX_NO_DEBUG" unless="debug" />
	<define name="FLX_NO_FOCUS_LOST_SCREEN" unless="debug" />
	<define name="FLX_NO_SOUND_TRAY" if="mobile" />

	<haxeflag name="-dce full" unless="debug" />
	<haxedef name="no-traces" unless="debug" />
	<haxedef name="analyzer-optimize" unless="debug" />

	<section if="debug">
		<haxedef name="debug" />
	</section>

	<certificate if="android"
		unless="debug"
		path="Certificates/android.keystore"
		password="android"
		alias="android"
		alias-password="android" />

	<architecture name="armv7" if="android" />
	<architecture name="arm64" if="android" />

	<config:android permissions="android.permission.INTERNET android.permission.WRITE_EXTERNAL_STORAGE android.permission.READ_EXTERNAL_STORAGE" />
	<config:android target-sdk-version="35" />
	<config:android minimum-sdk-version="21" />
	<config:android install-location="auto" />
	<config:android window-soft-input-mode="adjustResize" />
	<config:android hardware-accelerated="true" />

	<config:ios deployment="12.0" />
	<config:ios device="universal" />
	<config:ios extension="false" />

	<config:html5 title="Shark" />
	<config:html5 background-color="#00111F" />
	<config:html5 vertical-sync="false" />

</project>
